# SecuGo environment variables
# Copy to .env.local and fill in your real values.
# The app runs in mock mode if Supabase keys are missing.

# Supabase (server + client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional — used by the AI assistant when wired up
OPENAI_API_KEY=

# Optional — GitHub App credentials for repo access (separate from Supabase OAuth)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
